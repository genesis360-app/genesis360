# Variables de entorno para tests E2E — Playwright
# Copiar este archivo a .env.test.local y completar los valores REALES.
# .env.test.local NO debe commitearse (está en .gitignore).

# URL base de la app a testear (DEV local o preview de Vercel)
E2E_BASE_URL=http://localhost:5173

# Usuario de prueba en el ambiente DEV de Supabase (gcmhzdedrkmmzfzfveig)
# Crear en Supabase Dashboard → Authentication → Users → Invite user
E2E_EMAIL=test@tu-dominio.com
E2E_PASSWORD=tu-password-seguro

# (Opcional) Si testeas contra una URL de Vercel preview en vez de local,
# asegurarse de deshabilitar Vercel Authentication en esa URL.
